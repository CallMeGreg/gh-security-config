# VHS tape file for demonstrating the `apply` command
# Run with: vhs demo/apply.tape

Output demo/apply.gif

Set Shell "zsh"
Set FontSize 18
Set Width 1400
Set Height 700
Set Padding 20
Set Theme "Dark+"

Type "gh security-config apply"
Enter
Sleep 2s
Type "github"
Enter
Sleep 2s
Type "callmegreg-6byeyj.ghe-test.net"
Enter
Sleep 2s
Enter
Sleep 2s
Type "first-org"
Enter
Sleep 2s
Down
Sleep 1s
Down
Sleep 1s
Enter
Sleep 4s
Enter
Sleep 2s
Type "y"
Sleep 3s
Type "y"
Sleep 25s